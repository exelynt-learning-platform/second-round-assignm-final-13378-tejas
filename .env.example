# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/ecommerce_db
DB_USERNAME=postgres
DB_PASSWORD=your_strong_password_here

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_random_256_bit_secret_string_at_least_32_chars

# Stripe — from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook secret — from https://dashboard.stripe.com/webhooks
# Set this after registering POST /api/payment/webhook as your webhook URL
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
